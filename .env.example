# MAGIVER — Variables de entorno
# Copiá este archivo como .env y completá los valores.

# Ya tenés estos datos en utils/supabase/info.tsx, pero podés sobreescribirlos acá:
VITE_SUPABASE_URL=https://dffzlkpzjlocilyqvnef.supabase.co
VITE_SUPABASE_ANON_KEY=pegar_aca_tu_anon_key

# Poner en "false" para dejar de usar datos simulados y hablar con Supabase real
VITE_MOCK_MODE=false

# Monitoreo de errores en producción (Sentry). DSN público del proyecto,
# seguro de exponer en el cliente.
VITE_SENTRY_DSN=pegar_aca_tu_dsn_de_sentry

# Clave de Google Maps restringida a la app Android (paquete + huella SHA-1
# del keystore de firma) — la clave web (restringida por dominio) no
# funciona dentro del WebView nativo. Ver Fase 2 del plan de Capacitor.
VITE_MAPS_API_KEY_ANDROID=pegar_aca_tu_clave_de_maps_para_android
